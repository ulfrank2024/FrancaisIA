generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id
  email     String   @unique
  fullName  String
  avatarUrl String?
  level     Level    @default(A1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  results   Result[]
}

model Question {
  id          String   @id @default(cuid())
  section     Section
  level       Level
  question    String
  options     Json?
  answer      String?
  explanation String?
  audioUrl    String?
  tags        String[] @default([])
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Result {
  id        String        @id @default(cuid())
  userId    String
  section   ResultSection
  score     Int
  total     Int
  correct   Int
  details   Json          @default("[]")
  durationS Int?
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Level {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum Section {
  CO
  CE
  EE
  EO
}

enum ResultSection {
  CO
  CE
  EE
  EO
  MOCK
}
