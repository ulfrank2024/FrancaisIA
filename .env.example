# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379

# ── JWT ──────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=changeme_access_secret_64chars_minimum
JWT_REFRESH_SECRET=changeme_refresh_secret_64chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Anthropic Claude ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Services URLs (utilisé par le gateway) ───────────────────────
AUTH_SERVICE_URL=http://auth-service:4001
CONTENT_SERVICE_URL=http://content-service:4002
AI_SERVICE_URL=http://ai-service:4003
PROGRESS_SERVICE_URL=http://progress-service:4004

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
ALLOWED_ORIGIN=http://localhost:3000

# ── Ports ────────────────────────────────────────────────────────
GATEWAY_PORT=4000
AUTH_PORT=4001
CONTENT_PORT=4002
AI_PORT=4003
PROGRESS_PORT=4004
