# ── Neon PostgreSQL ──────────────────────────────────────────────
# Neon Console > ton projet > Connection Details > Connection string
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# URL directe (sans pooler) — utilisée par Prisma pour les migrations
DIRECT_URL=postgresql://neondb_owner:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Clerk ─────────────────────────────────────────────────────────
# Clerk Dashboard > API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379

# ── Anthropic Claude ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ───────────────────────────────────────────────────────
# Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...
# Stripe Dashboard > Developers > Webhooks > ton endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Payment Links — Stripe Dashboard > Payment Links > copier l'ID (plink_xxx)
# Optionnel : si tu mets plan=bronze/silver/gold dans les Metadata du Payment Link,
# ces variables ne sont pas nécessaires
STRIPE_PAYMENT_LINK_BRONZE=plink_...
STRIPE_PAYMENT_LINK_SILVER=plink_...
STRIPE_PAYMENT_LINK_GOLD=plink_...

# URLs des Payment Links (utilisées dans /pricing)
NEXT_PUBLIC_STRIPE_BRONZE_URL=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_SILVER_URL=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_GOLD_URL=https://buy.stripe.com/...

# ── Sécurité interne (gateway → progress-service) ────────────────
# Générer avec : openssl rand -hex 32
INTERNAL_SECRET=changeme_internal_secret_hex

# ── Services URLs (utilisé par le gateway) ───────────────────────
AUTH_SERVICE_URL=http://auth-service:4001
CONTENT_SERVICE_URL=http://content-service:4002
AI_SERVICE_URL=http://ai-service:4003
PROGRESS_SERVICE_URL=http://progress-service:4004

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
ALLOWED_ORIGIN=http://localhost:3000

# ── Ports ────────────────────────────────────────────────────────
GATEWAY_PORT=4000
AUTH_PORT=4001
CONTENT_PORT=4002
AI_PORT=4003
PROGRESS_PORT=4004
